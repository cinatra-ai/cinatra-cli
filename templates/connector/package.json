{
  "name": "{{packageName}}",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "{{description}}",
  "type": "module",
  "files": [
    "src",
    "cinatra"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./register": "./src/register.ts"
  },
  "peerDependencies": {
    "@cinatra-ai/sdk-extensions": "{{sdkPin}}"
  },
  "peerDependenciesMeta": {
    "@cinatra-ai/sdk-extensions": {
      "optional": true
    }
  },
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "connector",
    "displayName": "{{displayName}}",
    "dependencies": [],
    "serverEntry": "./register",
    "requestedHostPorts": [
      "capabilities"
    ],
    "sdkAbiRange": "{{sdkAbiRange}}",
    "migrationsDir": "cinatra/migrations"
  }
}
