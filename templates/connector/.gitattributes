# Trim CI/internal noise from `git archive` exports (GitHub release "Source
# code" archives are produced by git-archive, which honors export-ignore).
# Directory-content rules use the `/**` form. npm tarball contents are governed
# by the package.json "exports" map (a connector publishes its built register
# entry + public surface, never the CI config).
.gitattributes export-ignore
.gitignore export-ignore
.github export-ignore
.github/** export-ignore
tsconfig.json export-ignore
renovate.json export-ignore
.npmrc export-ignore
**/__tests__ export-ignore
**/__tests__/** export-ignore
*.test.* export-ignore
*.spec.* export-ignore
vitest.config.* export-ignore
