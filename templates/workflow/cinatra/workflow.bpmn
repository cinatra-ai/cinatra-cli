<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:cinatra="http://cinatra.ai/schema/bpmn/profile-1.0"
  id="{{slug}}-defs"
  targetNamespace="http://cinatra.ai/schema/bpmn/profile-1.0">
  <bpmn:process id="{{slug}}" name="{{displayName}}" isExecutable="false">
    <bpmn:documentation>Minimal review-gated workflow: start -> approval -> end. Replace with your real DAG.</bpmn:documentation>
    <bpmn:extensionElements>
      <cinatra:workflowMeta name="{{displayName}}" />
      <cinatra:placeholders>
        <cinatra:placeholder name="subjectId" type="string" required="true" description="The id of the object this workflow operates on" />
      </cinatra:placeholders>
    </bpmn:extensionElements>

    <bpmn:startEvent id="start" name="Start" />

    <bpmn:userTask id="review" name="Review and approve">
      <bpmn:extensionElements>
        <cinatra:taskKind value="approval" />
        <cinatra:approvalConfig level="organization" rejectionPolicy="needs_revision" />
      </bpmn:extensionElements>
    </bpmn:userTask>

    <bpmn:endEvent id="end" name="End" />

    <bpmn:sequenceFlow id="flow_start_review" sourceRef="start" targetRef="review" />
    <bpmn:sequenceFlow id="flow_review_end" sourceRef="review" targetRef="end">
      <bpmn:extensionElements>
        <cinatra:transitionOutcome outcome="success" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
  </bpmn:process>
</bpmn:definitions>
