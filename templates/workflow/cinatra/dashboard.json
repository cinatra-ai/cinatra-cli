{
  "apiVersion": "v1.2",
  "scopeLevel": "project",
  "portlets": [
    {
      "instanceId": "subjects-pane",
      "kind": "object-list",
      "version": "1.0.0",
      "slot": "fixed",
      "config": { "typeId": "{{packageName}}:subject" },
      "outputs": ["selectedId"]
    },
    {
      "instanceId": "subject-detail",
      "kind": "object-detail",
      "version": "1.0.0",
      "slot": "fixed",
      "config": {},
      "inputs": { "objectId": { "fromInstanceId": "subjects-pane", "key": "selectedId" } }
    },
    {
      "instanceId": "workflow-status",
      "kind": "workflow-status",
      "version": "1.0.0",
      "slot": "fixed",
      "config": {},
      "inputs": { "subjectId": { "fromInstanceId": "subjects-pane", "key": "selectedId" } }
    }
  ]
}
