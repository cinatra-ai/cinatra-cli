# Trim CI/internal noise from `git archive` exports (GitHub release "Source
# code" archives are produced by git-archive, which honors export-ignore).
# Directory-content rules use the `/**` form: a bare `dir/` pattern does not
# recurse for export-ignore. The slash-less dir rules drop the (otherwise empty)
# directory entries themselves. npm tarball contents are governed separately by
# the package.json "files" allowlist.
.gitattributes export-ignore
.gitignore export-ignore
.github export-ignore
.github/** export-ignore
extension-kind-gate.mjs export-ignore
tsconfig.json export-ignore
renovate.json export-ignore
.npmrc export-ignore
